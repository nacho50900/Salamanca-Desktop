<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Ruta de los Arribes del Duero</name>
    <description>Espectacular ruta en bicicleta por el Parque Natural de los Arribes del Duero,
            donde el río Duero forma profundas gargantas entre las fronteras de España y Portugal.
            La ruta ofrece vistas panorámicas impresionantes, pueblos medievales y una rica
            biodiversidad con </description>

    <!-- Estilo para los marcadores de hitos -->
    <Style id="hitoStyle">
      <IconStyle>
        <color>ff1400ff</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/red-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ff1400ff</color>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>

    <!-- Estilo para la línea de trazado -->
    <Style id="lineaRuta">
      <LineStyle>
        <color>ff0000ff</color>
        <width>3</width>
      </LineStyle>
    </Style>

    <!-- Hito 0: Mirador Monte del Puerto -->
    <Placemark>
      <name>Mirador Monte del Puerto</name>
      <description>Gran mirador del cañon del duero. Des aquí es habitual 
                    avistar buitres leonados sobrevolando las hoces.</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-6.6538,41.2284,650.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 1: Mirador del Picón de Felipe -->
    <Placemark>
      <name>Mirador del Picón de Felipe</name>
      <description>Uno de los miradores más espectaculares de los Arribes. Desde aquí
                    se domina una panorámica de 360 grados del cañón del Duero y la frontera
                    con Portugal.</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-6.6775,41.2188,471.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 2: Corporario -->
    <Placemark>
      <name>Corporario</name>
      <description>Pequeña aldea prácticamente deshabitada que conserva la arquitectura
                    de pizarra característica de la zona. Sus calles empedradas y bodegas
                    tradicionales transpo</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-6.6074,41.2153,709.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 3: Vilvestre -->
    <Placemark>
      <name>Vilvestre</name>
      <description>Precioso pueblo con arquitectura tradicional de la raya hispanoportuguesa.
                    Su iglesia parroquial de estilo románico tardío data del siglo XIII.
                    Desde aquí se or</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-6.7235,41.1063,713.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 4: Mirador de Mafeito -->
    <Placemark>
      <name>Mirador de Mafeito</name>
      <description>El Mirador de Mafeito ofrece una panorámica espectacular del cañón fluvial,
                    al meandro del Duero que separa España y Portugal.</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-6.8652,41.02235,345.0</coordinates>
      </Point>
    </Placemark>

    <!-- Trazado completo de la ruta -->
    <Placemark>
      <name>Trazado - Ruta de los Arribes del Duero</name>
      <styleUrl>#lineaRuta</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <altitudeMode>clampToGround</altitudeMode>
        <coordinates>
          -6.6538,41.2284,650.0
          -6.6775,41.2188,471.0
          -6.6074,41.2153,709.0
          -6.7235,41.1063,713.0
          -6.8652,41.02235,345.0
        </coordinates>
      </LineString>
    </Placemark>

  </Document>
</kml>