<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Ruta Monumental de Salamanca</name>
    <description>Recorrido por los monumentos más emblemáticos del casco histórico de Salamanca,
            Patrimonio de la Humanidad. La ruta discurre por la Universidad, la Catedral Vieja
            y Nueva, la Casa de las Conchas y la impresionante Plaza Mayor, joya del barroco español.</description>

    <!-- Estilo para los marcadores de hitos -->
    <Style id="hitoStyle">
      <IconStyle>
        <color>ff1400ff</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/red-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ff1400ff</color>
        <scale>0.8</scale>
      </LabelStyle>
    </Style>

    <!-- Estilo para la línea de trazado -->
    <Style id="lineaRuta">
      <LineStyle>
        <color>ff0000ff</color>
        <width>3</width>
      </LineStyle>
    </Style>

    <!-- Hito 0: Plaza Mayor -->
    <Placemark>
      <name>Plaza Mayor</name>
      <description></description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-5.6638,40.9651,800.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 1: Plaza Mayor -->
    <Placemark>
      <name>Plaza Mayor</name>
      <description>La Plaza Mayor de Salamanca es considerada una de las más bellas de España.
                    Construida entre 1729 y 1756 por los arquitectos Alberto Churriguera y Andrés García de Quiñones,
      </description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-5.6638,40.9651,800.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 2: Casa de las Conchas -->
    <Placemark>
      <name>Casa de las Conchas</name>
      <description>Edificio gótico-plateresco construido a finales del siglo XV por Rodrigo Arias Maldonado.
                    Su nombre proviene de las más de 300 conchas de piedra que decoran su fachada,
           </description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-5.6672,40.964,798.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 3: Universidad de Salamanca -->
    <Placemark>
      <name>Universidad de Salamanca</name>
      <description>Fundada en 1218, es una de las universidades más antiguas del mundo.
                    Su fachada plateresca (1534) es considerada la obra más representativa del estilo
                    plateresc</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-5.668,40.9628,795.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 4: Catedral Nueva de Salamanca -->
    <Placemark>
      <name>Catedral Nueva de Salamanca</name>
      <description>Construida entre los siglos XVI y XVIII, combina los estilos gótico tardío,
                    plateresco y barroco. Destaca su torre campanario de 110 metros de altura.
                    Comparte </description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-5.6695,40.9609,793.0</coordinates>
      </Point>
    </Placemark>

    <!-- Hito 5: Puente Romano -->
    <Placemark>
      <name>Puente Romano</name>
      <description>El Puente Romano de Salamanca data del siglo I a.C. y fue construido
                    sobre el río Tormes por orden del emperador romano Trajano. Consta de 26 arcos
                    y mide 180 m</description>
      <styleUrl>#hitoStyle</styleUrl>
      <Point>
        <coordinates>-5.668,40.957,790.0</coordinates>
      </Point>
    </Placemark>

    <!-- Trazado completo de la ruta -->
    <Placemark>
      <name>Trazado - Ruta Monumental de Salamanca</name>
      <styleUrl>#lineaRuta</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <altitudeMode>clampToGround</altitudeMode>
        <coordinates>
          -5.6638,40.9651,800.0
          -5.6638,40.9651,800.0
          -5.6672,40.964,798.0
          -5.668,40.9628,795.0
          -5.6695,40.9609,793.0
          -5.668,40.957,790.0
        </coordinates>
      </LineString>
    </Placemark>

  </Document>
</kml>